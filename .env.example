# ============================================================================
# ZENDESK - Ticket Management API
# ============================================================================
ZENDESK_EMAIL=your-email@company.com
ZENDESK_API_TOKEN=your-api-token
ZENDESK_DOMAIN=yourcompany
ZENDESK_BRAND_ID=360000000000

# ============================================================================
# ZENDESK SUNSHINE - Conversational AI / Chatbot
# ============================================================================
SUNSHINE_KEY_ID=your-sunshine-key-id
SUNSHINE_KEY_SECRET=your-sunshine-key-secret
SUNSHINE_APP_ID=your-app-id

# ============================================================================
# CLAUDE AI - Knowledge Base Search using Files API (NEW)
# ============================================================================
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-1
CLAUDE_MAX_TOKENS=2048

# Integration IDs for routing to brand-specific files
INTEGRATION_ID_AFFINITY=affinity-integration-id
INTEGRATION_ID_ETHOS=ethos-integration-id
INTEGRATION_ID_ITBYTES=itbytes-integration-id

# ============================================================================
# OPENAI - LLM for Response Generation
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# ============================================================================
# PINECONE - Vector Database (Optional)
# ============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=zendesk-kb
PINECONE_DIMENSION=1536

# ============================================================================
# Application Settings
# ============================================================================
NODE_ENV=development
PORT=3000
